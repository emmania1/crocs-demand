# Copy to .env and fill in. Most fetchers work without any of these.
# Only Reddit (optional) uses keys; everything else is public.

# Reddit — OPTIONAL, public JSON API works without auth but has tighter limits.
# If you want auth, create an app at reddit.com/prefs/apps (script type):
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crocs-demand-tracker-by-<your-reddit-username>

# Keepa API key — OPTIONAL, only if scraping Amazon Best Sellers starts failing
# and you want the paid fallback. Sign up at keepa.com/#!api
KEEPA_API_KEY=
